{
  "name": "agentai",
  "version": "1.0.0",
  "description": "AI-powered communication management platform",
  "main": "src/server.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "node --watch src/server.js",
    "postinstall": "prisma generate",
    "start": "prisma migrate deploy && node src/server.js",
    "db:migrate": "npx prisma migrate dev",
    "db:seed": "node scripts/seed.js",
    "db:studio": "npx prisma studio",
    "setup": "npm install && npx prisma migrate dev --name init && node scripts/seed.js",
    "webhook:test": "node scripts/trigger-local-webhook.js"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "expr-eval": "^2.0.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "openai": "^4.73.0",
    "twilio": "^4.23.0",
    "prisma": "^5.22.0",
    "uuid": "^9.0.1",
    "ws": "^8.18.0",
    "winston": "^3.14.0"
  },
  "devDependencies": {}
}
