# App
# --- Production (e.g. Railway): set NODE_ENV=production and APP_URL to your public https URL ---
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# Prisma SQL logs (development): query logs default ON when NODE_ENV !== production.
# Set PRISMA_QUERY_LOG=false to silence [Prisma] query lines.
# PRISMA_QUERY_LOG=false
JWT_SECRET=change-this-to-a-random-string-at-least-32-chars

# Database — PostgreSQL (Docker: docker compose up -d)
# DATABASE_URL="postgresql://agentai:name12345678@localhost:5432/agentai"
# Verify: npm run db:ping
# If login fails on Windows, port 5432 may be a different Postgres install — run
# scripts/create-dev-db.sql as superuser, or use Docker and this URL.
# SQLite (legacy local):
# DATABASE_URL="file:./dev.db"

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Sandbox default — override with your approved WhatsApp sender once you have one
TWILIO_WHATSAPP_FROM=+14155238886

# Set to "true" only for local testing without real Twilio webhooks (curl tests).
# In any environment that receives real Twilio traffic, leave this unset/false
# so that webhook signatures are validated and spoofed requests are rejected.
SKIP_TWILIO_SIGNATURE=false

# ElevenLabs
ELEVENLABS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LLM via OpenRouter (single key for all models)
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini

# Deepgram (Speech-to-Text)
DEEPGRAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Ngrok (development — paste your ngrok URL after starting it)
NGROK_URL=https://xxxx.ngrok-free.app
